{
  "name": "crea-ddf-mcp",
  "version": "0.0.1",
  "description": "MCP server exposing the CREA DDF SDK and synced Postgres query tools.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "crea-ddf-mcp": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "typecheck": "tsgo --noEmit",
    "build": "bun run typecheck && rm -rf dist && tsgo -p tsconfig.json",
    "start": "node ./dist/index.js",
    "dev": "bun run src/index.ts",
    "test": "bun run typecheck && vitest run",
    "publish:npm": "npm publish --access public --ignore-scripts"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE.md"
  ],
  "engines": {
    "node": ">=24.14.0",
    "bun": ">=1.3.0"
  },
  "keywords": [
    "crea",
    "ddf",
    "mcp",
    "model-context-protocol",
    "real-estate",
    "postgres",
    "effect"
  ],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "@effect/platform-bun": "4.0.0-beta.66",
    "@effect/sql-pg": "4.0.0-beta.66",
    "@cfworker/json-schema": "4.1.1",
    "@modelcontextprotocol/server": "2.0.0-alpha.2",
    "crea-ddf": "^0.0.3",
    "drizzle-orm": "1.0.0-rc.2",
    "effect": "4.0.0-beta.66",
    "pg": "8.20.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@effect/tsgo": "0.7.2",
    "@effect/vitest": "4.0.0-beta.65",
    "@types/bun": "1.3.14",
    "@types/node": "25.8.0",
    "@typescript/native-preview": "7.0.0-dev.20260517.1",
    "vitest": "4.1.6"
  }
}
