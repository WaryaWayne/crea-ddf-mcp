{
  "name": "crea-ddf-mcp",
  "version": "0.0.1",
  "description": "Read-only MCP server for querying synced CREA DDF Postgres data through the crea-ddf package.",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WaryaWayne/crea-ddf-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/WaryaWayne/crea-ddf-mcp/issues"
  },
  "homepage": "https://github.com/WaryaWayne/crea-ddf-mcp",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "crea-ddf-mcp": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "bun run typecheck && rm -rf dist && tsc -p tsconfig.json",
    "start": "node ./dist/index.js",
    "dev": "bun run src/index.ts",
    "test": "bun run typecheck && vitest run",
    "publish:npm": "bun run build && npm publish --access public --ignore-scripts",
    "prepare": "effect-language-service patch"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE.md"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=24.14.0",
    "bun": ">=1.3.0"
  },
  "keywords": [
    "crea",
    "ddf",
    "mcp",
    "model-context-protocol",
    "real-estate",
    "postgres",
    "effect"
  ],
  "author": "Warya Wayne",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "@cfworker/json-schema": "4.1.1",
    "@effect/platform-bun": "4.0.0-beta.66",
    "@effect/sql-pg": "4.0.0-beta.66",
    "@modelcontextprotocol/server": "2.0.0-alpha.2",
    "crea-ddf": "^0.0.5",
    "drizzle-orm": "1.0.0-rc.2",
    "effect": "4.0.0-beta.66",
    "pg": "8.20.0"
  },
  "devDependencies": {
    "@effect/language-service": "^0.86.2",
    "@effect/vitest": "4.0.0-beta.65",
    "@types/bun": "1.3.14",
    "@types/node": "25.9.1",
    "typescript": "6.0.3",
    "vitest": "4.1.7"
  }
}
